  "tool_choice": "end",
  "sql_query": "SELECT \n    Product_Class_Code, \n    AVG(CASE WHEN On_Promo = 1 THEN Total_Sale_Value / NULLIF(Qty_Sold, 0) END) AS Avg_Revenue_Per_Unit_Promo,\n    AVG(CASE WHEN On_Promo = 0 THEN Total_Sale_Value / NULLIF(Qty_Sold, 0) END) AS Avg_Revenue_Per_Unit_Non_Promo,\n    COUNT(CASE WHEN On_Promo = 1 THEN 1 END) AS Total_Transactions_Promo,\n    COUNT(CASE WHEN On_Promo = 0 THEN 1 END) AS Total_Transactions_Non_Promo,\n    ABS(AVG(CASE WHEN On_Promo = 1 THEN Total_Sale_Value / NULLIF(Qty_Sold, 0) END) - \n        AVG(CASE WHEN On_Promo = 0 THEN Total_Sale_Value / NULLIF(Qty_Sold, 0) END)) AS Abs_Difference\nFROM \n    sales\nWHERE \n    CAST(Sold_Date AS VARCHAR) LIKE '2021-%'\nGROUP BY \n    Product_Class_Code\nORDER BY \n    Abs_Difference DESC;",
