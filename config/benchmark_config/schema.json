{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArcoConfig",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "workflow": {
          "type": "string",
          "description": "Unique identifier for the workflow that should be executed in this benchmark run"
        },
        "run_id": {
          "type": "string",
          "description": "Unique identifier for this specific execution. Ignore to auto-generate a unique ID, or set a fixed string to enable reproducible caching behavior."
        },
        "enable_budget_controller": {
          "type": "boolean",
          "description": "Toggle to determine if the arco budget controller is enabled. Defaults to true",
          "default": "true"
        },
        "default_provider": {
          "type": "string",
          "enum": [
            "openai",
            "ollama",
            "openrouter"
          ],
          "description": "The AI model provider backend."
        },
        "default_model": {
          "type": "string",
          "description": "The specific model identifier."
        },
        "default_provider_judge": {
          "type": "string",
          "enum": [
            "openai",
            "ollama",
            "openrouter"
          ],
          "description": "The AI model provider backend for the LLM judges."
        },
        "default_model_judge": {
          "type": "string",
          "description": "The specific model identifier for the LLM judges."
        },
        "ollama_url": {
          "type": "string",
          "format": "uri",
          "description": "The base URL for local Ollama instances. Needed if provider is ollama"
        },
        "enable_storage": {
          "type": "boolean",
          "description": "Toggle to determine whether final output artifacts should be persisted to disk."
        },
        "save_dir": {
          "type": "string",
          "default": "./output",
          "description": "Directory path where output artifacts and execution metrics will be saved. This path is used also for codecarbon results"
        },
        "enable_codecarbon": {
          "type": "boolean",
          "description": "Toggle to enable codecarbon consumption measurements. The output dir is set with the save_dir option"
        }
      },
      "description": "Global execution parameters, provider credentials, caching rules, and runtime environmental toggles used by the agent infrastructure.",
      "required": []
    },
    "defaults": {
      "type": "object",
      "description": "Per-agent configuration settings.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "openai",
              "ollama"
            ],
            "description": "The AI model provider backend."
          },
          "model": {
            "type": "string",
            "description": "The specific model identifier."
          },
          "n": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of completions to generate."
          },
          "bon_param": {
            "type": "string",
            "enum": [
              "temperature",
              "top_k",
              "top_p"
            ],
            "description": "Best-of-N selection parameter."
          },
          "temp_min": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 2.0,
            "description": "Minimum sampling temperature limit."
          },
          "temp_max": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 2.0,
            "description": "Maximum sampling temperature limit."
          },
          "cot_n": {
            "type": "integer",
            "minimum": 1,
            "description": "Chain-of-thought generation count multiplier (optional)."
          },
          "top_p_min": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Minimum top_p (nucleus sampling) threshold limit."
          },
          "top_p_max": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Maximum top_p (nucleus sampling) threshold limit."
          },
          "top_k_min": {
            "type": "integer",
            "minimum": 1,
            "description": "Minimum top_k token cutoff pool limit."
          },
          "top_k_max": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum top_k token cutoff pool limit."
          },
          "max_tokens": {
            "type": "integer",
            "description": "Maximum number of tokens the agent should output at each generation"
          },
          "eval": {
            "type": "string",
            "enum": [
              "default"
            ],
            "description": "The evaluation system used by the agent to perform best-of-n selection"
          }
        },
        "description": "Dictionary of dynamic, named agent definitions (e.g., Retriever, Analyzer). All internal keys are optional, allowing individual agents to selectively override the global defaults or customize their own sampling boundaries, caching rules, and evaluation setups.",
        "required": []
      }
    },
    "runs": {
      "type": "array",
      "description": "Ordered list of benchmark runs, each optionally applying a named set of overrides to specific agents. Runs without 'changes' use the global/agent defaults as-is.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique identifier for this benchmark run."
          },
          "description": {
            "type": "string",
            "description": "Human-readable explanation of what this benchmark tests."
          },
          "changes": {
            "type": "object",
            "description": "Per-agent overrides applied for this run. Keys are agent names matching entries under 'agents'. Omit entirely to run with defaults unchanged.",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": ["openai", "ollama"]
                },
                "model": { "type": "string" },
                "n": { "type": "integer", "minimum": 1 },
                "bon_param": {
                  "type": "string",
                  "enum": ["temperature", "top_k", "top_p"]
                },
                "temp_min": { "type": "number", "minimum": 0.0, "maximum": 2.0 },
                "temp_max": { "type": "number", "minimum": 0.0, "maximum": 2.0 },
                "cot_n": { "type": "integer", "minimum": 1 },
                "top_p_min": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                "top_p_max": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
                "top_k_min": { "type": "integer", "minimum": 1 },
                "top_k_max": { "type": "integer", "minimum": 1 },
                "max_tokens": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Maximum output tokens for this agent."
                },
                "use_cache": { "type": "boolean" },
                "cache_mode": {
                  "type": "string",
                  "enum": ["read", "r", "write", "w", "read_write", "rw"]
                },
                "enabled": { "type": "boolean" },
                "eval": {
                  "type": "string",
                  "enum": ["default"]
                }
              },
              "additionalProperties": false
            }
          }
        },
        "required": ["name"]
      }
    }
  },
  "required": [
    "global",
    "runs"
  ]
}